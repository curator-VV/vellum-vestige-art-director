{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js dist-electron",
    "lint": "tsc --noEmit",
    "electron:dev": "node electron-launcher.js",
    "electron:pack": "npm run build && electron-builder"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.21.0",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "dotenv": "^17.2.3",
    "esbuild": "^0.25.0",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "tsx": "^4.21.0"
  },
  "description": "Vellum & Vestige Art Director Suite",
  "author": "Vellum & Vestige",
  "build": {
    "appId": "com.vellumvestige.artdirector",
    "productName": "V&V Art Director Suite",
    "directories": {
      "output": "../dist-electron-vv"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.photography"
    }
  }
}

          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                    Volume must be grounded upon raw, minimalist matte surfaces like raw grey concrete slabs, dark slate blocks, or coarse unbleached linen sheets. Glossy, high-reflection, or saturated surfaces are strictly forbidden."

      original_chunk {
        target_content: "            {/* Visualizer & Code Output Panel */}\n            <section className=\"flex-1 bg-[#EBE8E3] p-6 md:p-10 flex flex-col justify-between overflow-y-auto\">\n              \n              {/* Preview Canvas */}\n              <div className=\"flex-1 relative flex flex-col items-center justify-center min-h-[380px] py-6\">\n                \n                {/* Visual Director Floating Note */}\n                <div className=\"absolute top-0 right-0 max-w-xs text-[10px] leading-relaxed bg-[#F5F2ED]/90 p-3.5 border border-[#1F2022]/10 shadow-sm backdrop-blur-sm rounded-sm hidden sm:block\">\n                  <p className=\"font-bold uppercase mb-1 tracking-tighter text-[#1F2022] flex items-center gap-1\">\n                    <Eye className=\"w-3.5 h-3.5 text-[#C5A059]\" />\n                    <span>Visual Director Notes:</span>\n                  </p>\n                  <p className=\"font-serif italic text-[#1F2022]/80\">\n                    \"Ensure the gold foil stamp catches the morning daylight angle. Edge material edges must feel authentically layered and deckled.\"\n                  </p>\n                </div>\n\n                {/* Main Book Interactive Mockup (Closed / Open) */}\n                <div className=\"relative group transition-all duration-300\">\n                  {state === \"closed\" ? (\n                    // CLOSED MONOGRAPH MOCKUP\n                    <div \n                      id=\"book-mockup-closed\"\n                      style={{ \n                        backgroundColor: SWATCHES.find(s => s.id === swatch)?.hex,\n                        boxShadow: \"30px 40px 65px -15px rgba(0,0,0,0.45), inset -2px -2px 10px rgba(255,255,255,0.05)\"\n                      }} \n                      className=\"w-60 h-[320px] relative flex flex-col justify-between p-6 transition-all duration-500 rounded-sm border border-black/10\"\n                    >\n                      {/* Spine detail effect */}\n                      <div className=\"absolute inset-y-0 left-0 w-2.5 bg-gradient-to-r from-black/25 via-transparent to-transparent\"></div>\n                      <div className=\"absolute inset-y-0 left-2.5 w-[1px] bg-white/5\"></div>\n                      \n                      {/* Linen/Leather tactile textures */}\n                      {material === \"linen\" ? (\n                        <div className=\"absolute inset-0 opacity-15 pointer-events-none mix-blend-overlay bg-[radial-gradient(#1f2022_1px,transparent_1px)] [background-size:3px_3px]\"></div>\n                      ) : (\n                        <div className=\"absolute inset-0 opacity-10 pointer-events-none mix-blend-soft-light bg-[radial-gradient(circle,rgba(255,255,255,0.15)_10%,transparent_20%)] [background-size:5px_5px]\"></div>\n                      )}\n\n                      {/* Directional Sunlight simulation overlay */}\n                      <div className=\"absolute inset-0 pointer-events-none overflow-hidden rounded-sm\">\n                        <div className=\"absolute -left-1/3 top-0 w-[200%] h-full bg-gradient-to-tr from-transparent via-white/10 to-transparent rotate-[25deg] translate-x-12 translate-y-12 blur-md\"></div>\n                      </div>\n\n                      {/* Logo stamp top position */}\n                      {logoPosition === \"brand_default\" && (\n                        <div className=\"flex flex-col items-center mt-12 opacity-95 animate-pulse-slow\">\n                          <div className=\"border border-[#C5A059]/50 p-2.5 bg-gradient-to-br from-[#E2C98F] via-[#C5A059] to-[#99793C] text-transparent bg-clip-text font-serif text-3xl font-bold tracking-tighter select-none shadow-[0px_2px_4px_rgba(0,0,0,0.3)]\">\n                            VV\n                          </div>\n                          <div className=\"h-14 w-[1px] bg-gradient-to-b from-[#C5A059]/40 to-transparent mt-2\"></div>\n                        </div>\n                      )}\n\n                      {/* Centered Series / Volume Title */}\n                      {logoPosition === \"user_centered_bottom\" ? (\n                        <div className=\"flex-1 flex flex-col items-center justify-center text-center px-4 relative z-10 select-none mt-12\">\n                          <p className=\"font-serif text-[10px] uppercase tracking-[0.25em] bg-gradient-to-r from-[#E2C98F] via-[#C5A059] to-[#99793C] text-transparent bg-clip-text font-semibold drop-shadow-sm\">\n                            {VOLUMES.find(v => v.id === selectedVolume)?.label}\n                          </p>\n                          <p className=\"font-serif text-[13px] md:text-sm tracking-wide bg-gradient-to-r from-[#E2C98F] via-[#C5A059] to-[#99793C] text-transparent bg-clip-text font-normal leading-relaxed drop-shadow-sm mt-1\">\n                            {VOLUMES.find(v => v.id === selectedVolume)?.title}\n                          </p>\n                          <div className=\"w-8 h-[1px] bg-gradient-to-r from-transparent via-[#C5A059]/40 to-transparent mt-2.5\"></div>\n                        </div>\n                      ) : (\n                        <div className=\"flex-1\"></div>\n                      )}\n\n                      {/* Cover Details Bottom */}\n                      <div className=\"relative z-10 text-center\">\n                        {logoPosition === \"user_centered_bottom\" ? (\n                          <div className=\"flex flex-col items-center mb-4 mt-auto select-none\">\n                            <div className=\"flex flex-col items-center opacity-95 animate-pulse-slow\">\n                              {/* Beautiful script/calligraphy style VV Monogram */}\n                              <div className=\"font-serif italic text-3xl font-light tracking-tighter bg-gradient-to-br from-[#E2C98F] via-[#C5A059] to-[#99793C] text-transparent bg-clip-text drop-shadow-[0px_1px_2px_rgba(0,0,0,0.3)] select-none leading-none\">\n                                \360\235\222\261\360\235\222\261\n                              </div>\n                              <div className=\"h-1.5 w-[1px] bg-gradient-to-b from-[#C5A059]/40 to-transparent mt-0.5\"></div>\n                              <p className=\"text-[5.5px] uppercase tracking-[0.3em] font-serif bg-gradient-to-r from-[#E2C98F] via-[#C5A059] to-[#99793C] text-transparent bg-clip-text font-bold mt-1.5\">\n                                Vellum & Vestige\n                              </p>\n                            </div>\n                          </div>\n                        ) : (\n                          <>\n                            <div className=\"h-px bg-white/10 w-full mb-2\"></div>\n                            <p className={`text-[7.5px] uppercase tracking-[0.4em] text-center ${\n                              SWATCHES.find(s => s.id === swatch)?.textLight ? \"text-white/40\" : \"text-black/40\"\n                            }`}>\n                              {VOLUMES.find(v => v.id === selectedVolume)?.label}: {VOLUMES.find(v => v.id === selectedVolume)?.title}\n                            </p>\n                          </>\n                        )}\n                      </div>\n                    </div>\n                  ) : (\n                    // OPEN SPREAD MOCKUP\n                    <div className=\"flex flex-col items-center\">\n                      <div className=\"flex w-[340px] md:w-[480px] h-[220px] md:h-[280px] shadow-[40px_35px_65px_-15px_rgba(0,0,0,0.35)] relative bg-[#FCFAF7] border-y border-stone-200\">\n                        \n                        {/* Shadow casting in the center page fold */}\n                        <div className=\"absolute inset-y-0 left-1/2 -translate-x-1/2 w-4 bg-gradient-to-r from-black/10 via-black/25 to-black/10 z-20\"></div>\n\n                        {/* Left Page (Blank heavy cotton texture) */}\n                        <div className=\"w-1/2 h-full bg-[#FCFAF7] p-5 relative border-r border-stone-100 flex flex-col justify-between\">\n                          <div className=\"absolute inset-0 bg-stone-500/5 mix-blend-multiply rounded-l-sm\"></div>\n                          <div className=\"w-8 h-[1px] bg-stone-300\"></div>\n                          <div className=\"space-y-1.5 opacity-30\">\n                            <div className=\"h-1 bg-stone-400 w-1/2\"></div>\n                            <div className=\"h-1 bg-stone-400 w-3/4\"></div>\n                            <div className=\"h-1 bg-stone-400 w-1/3\"></div>\n                          </div>\n                          <span className=\"text-[7px] font-mono tracking-widest text-stone-400\">VELLUM & VESTIGE</span>\n                        </div>\n\n                        {/* Right Page (Contains Heartwarming Editorial Photo) */}\n                        <div className=\"w-1/2 h-full bg-[#FCFAF7] p-4 relative flex flex-col justify-between\">\n                          <div className=\"absolute inset-0 bg-stone-500/5 mix-blend-multiply rounded-r-sm\"></div>\n                          \n                          {/* Inner Styled Photo frame simulating real visualizer */}\n                          <div className=\"flex-1 bg-stone-100 border border-stone-200 rounded-sm relative overflow-hidden flex flex-col justify-center items-center p-2 text-center\">\n                            \n                            {/* Texture filter according to Style (B&W or analog color) */}\n                            <div className={`absolute inset-0 ${\n                              photoStyle === \"bw\" \n                                ? \"bg-gradient-to-br from-stone-300 to-stone-500 grayscale\" \n                                : \"bg-gradient-to-br from-amber-100/40 via-orange-100/30 to-amber-900/10\"\n                            } opacity-40 mix-blend-multiply z-10`}></div>\n\n                            {/* Warm natural sunray on photo */}\n                            <div className=\"absolute top-0 right-0 w-full h-full bg-gradient-to-tr from-transparent via-amber-200/20 to-transparent rotate-12 blur-sm z-10\"></div>\n\n                            {/* Display custom subject graphics/text */}\n                            <div className=\"relative z-10 flex flex-col items-center\">\n                              <span className=\"text-[8px] uppercase tracking-widest font-mono text-[#1F2022] bg-[#F5F2ED] px-2 py-0.5 shadow-sm rounded-sm\">\n                                {OPEN_PHOTO_THEMES.find(t => t.id === photoTheme)?.name}\n                              </span>\n                              <p className=\"text-[9px] font-serif italic text-stone-700 mt-2 max-w-[140px] leading-tight\">\n                                \"{OPEN_PHOTO_THEMES.find(t => t.id === photoTheme)?.desc.substring(0, 52)}...\"\n                              </p>\n                            </div>\n                            \n                            {/* Aesthetic photo camera stamp */}\n                            <div className=\"absolute bottom-1 right-2 text-[6px] text-stone-400 font-mono tracking-tighter\">\n                              HASSELBLAD 80MM F/2.8\n                            </div>\n                          </div>\n\n                          <div className=\"flex justify-between items-center mt-2.5 text-[7px] font-mono text-stone-400\">\n                            <span>SENSITIVE SERIES COMP</span>\n                            <span>PL. 09</span>\n                          </div>\n                        </div>\n\n                        {/* Visual representation of the colored book cover edges protruding underneath */}\n                        <div \n                          style={{ backgroundColor: SWATCHES.find(s => s.id === swatch)?.hex }} \n                          className=\"absolute bottom-[-4px] left-[2px] right-[2px] h-[4px] shadow-md rounded-b-sm\"\n                        ></div>\n                      </div>\n                      <p className=\"text-[10px] uppercase font-mono mt-3 tracking-widest text-stone-500\">\n                        Open cotton spread: 12\" x 9\" structural proportion\n                      </p>\n                    </div>\n                  )}\n                </div>"
        replacement_content: "            {/* Visualizer & Code Output Panel */}\n            <section className=\"flex-1 bg-[#EBE8E3] p-6 md:p-10 flex flex-col justify-between overflow-y-auto\">\n              \n              {/* Preview Canvas */}\n              <div className=\"flex-1 relative flex flex-col items-center justify-center min-h-[380px] py-6\">\n                \n                {/* Mode Selector Tabs at the Top Center of Preview Canvas */}\n                <div className=\"absolute top-0 left-0 right-0 flex justify-center gap-4 z-20\">\n                  <div className=\"bg-[#1F2022]/5 p-0.5 rounded-full flex gap-1 border border-[#1F2022]/10\">\n                    <button\n                      onClick={() => setViewMode(\"draft\")}\n                      className={`px-3 py-1 text-[10px] uppercase tracking-wider font-semibold rounded-full transition-all cursor-pointer ${\n                        viewMode === \"draft\"\n                          ? \"bg-[#1F2022] text-[#D7CEBE] shadow-sm\"\n                          : \"text-[#1F2022]/60 hover:text-[#1F2022]\"\n                      }`}\n                    >\n                      CAD Mockup Draft\n                    </button>\n                    <button\n                      onClick={() => {\n                        setViewMode(\"photo\");\n                        if (!generatedImageUrl && !isGenerating) {\n                          handleGenerateImage();\n                        }\n                      }}\n                      className={`px-3 py-1 text-[10px] uppercase tracking-wider font-semibold rounded-full transition-all flex items-center gap-1 cursor-pointer ${\n                        viewMode === \"photo\"\n                          ? \"bg-[#1F2022] text-[#D7CEBE] shadow-sm\"\n                          : \"text-[#1F2022]/60 hover:text-[#1F2022]\"\n                      }`}\n                    >\n                      <Sparkles className=\"w-3 h-3 text-[#C5A059]\" />\n                      <span>AI Photorealism</span>\n                    </button>\n                  </div>\n                </div>\n\n                {/* Visual Director Floating Note */}\n                <div className=\"absolute top-0 right-0 max-w-[200px] text-[10px] leading-relaxed bg-[#F5F2ED]/90 p-3 border border-[#1F2022]/10 shadow-sm backdrop-blur-sm rounded-sm hidden sm:block\">\n                  <p className=\"font-bold uppercase mb-1 tracking-tighter text-[#1F2022] flex items-center gap-1\">\n                    <Eye className=\"w-3.5 h-3.5 text-[#C5A059]\" />\n                    <span>Visual Director Notes:</span>\n                  </p>\n                  <p className=\"font-serif italic text-[#1F2022]/80\">\n                    \"Ensure the gold foil stamp catches the morning daylight angle. Edge material edges must feel authentically layered and deckled.\"\n                  </p>\n                </div>\n\n                {/* Main Render Area depending on viewMode */}\n                {viewMode === \"draft\" ? (\n                  <>\n                    {/* Main Book Interactive Mockup (Closed / Open) */}\n                    <div className=\"relative group transition-all duration-300\">\n                      {state === \"closed\" ? (\n                        // CLOSED MONOGRAPH MOCKUP\n                        <div \n                          id=\"book-mockup-closed\"\n                          style={{ \n                            backgroundColor: SWATCHES.find(s => s.id === swatch)?.hex,\n                            boxShadow: \"30px 40px 65px -15px rgba(0,0,0,0.45), inset -2px -2px 10px rgba(255,255,255,0.05)\"\n                          }} \n                          className=\"w-60 h-[320px] relative flex flex-col p-6 transition-all duration-500 rounded-sm border border-white/5 overflow-hidden\"\n                        >\n                          {/* Spine detail effect */}\n                          <div className=\"absolute inset-y-0 left-0 w-2.5 bg-gradient-to-r from-black/25 via-transparent to-transparent\"></div>\n                          <div className=\"absolute inset-y-0 left-2.5 w-[1px] bg-white/5\"></div>\n                          \n                          {/* Linen/Leather tactile textures */}\n                          {material === \"linen\" ? (\n                            <div className=\"absolute inset-0 opacity-15 pointer-events-none mix-blend-overlay bg-[radial-gradient(#1f2022_1px,transparent_1px)] [background-size:3px_3px]\"></div>\n                          ) : (\n                            <div className=\"absolute inset-0 opacity-10 pointer-events-none mix-blend-soft-light bg-[radial-gradient(circle,rgba(255,255,255,0.15)_10%,transparent_20%)] [background-size:5px_5px]\"></div>\n                          )}\n\n                          {/* Directional Sunlight simulation overlay */}\n                          <div className=\"absolute inset-0 pointer-events-none overflow-hidden rounded-sm\">\n                            <div className=\"absolute -left-1/3 top-0 w-[200%] h-full bg-gradient-to-tr from-transparent via-white/10 to-transparent rotate-[25deg] translate-x-12 translate-y-12 blur-md\"></div>\n                          </div>\n\n                          {/* Series / Volume Title - Placed about 1/3 of the way from the top */}\n                          <div className=\"mt-[25%] mb-auto flex flex-col items-center text-center px-4 relative z-10 select-none\">\n                            <p className=\"font-serif text-[9px] uppercase tracking-[0.25em] bg-gradient-to-r from-[#E2C98F] via-[#C5A059] to-[#99793C] text-transparent bg-clip-text font-semibold drop-shadow-sm\">\n                              {VOLUMES.find(v => v.id === selectedVolume)?.label}\n                            </p>\n                            <p className=\"font-serif text-[12px] md:text-[13px] tracking-wide bg-gradient-to-r from-[#E2C98F] via-[#C5A059] to-[#99793C] text-transparent bg-clip-text font-normal leading-relaxed drop-shadow-sm mt-1\">\n                              {VOLUMES.find(v => v.id === selectedVolume)?.title}\n                            </p>\n                            <div className=\"w-6 h-[1px] bg-gradient-to-r from-transparent via-[#C5A059]/40 to-transparent mt-2.5\"></div>\n                          </div>\n\n                          {/* Cover Details Bottom Monogram - Centers bottom strictly as requested */}\n                          <div className=\"relative z-10 text-center mb-2 mt-auto select-none\">\n                            <div className=\"flex flex-col items-center opacity-95 animate-pulse-slow\">\n                              {/* Beautiful script/calligraphy style VV Monogram */}\n                              <div className=\"font-serif italic text-3xl font-light tracking-tighter bg-gradient-to-br from-[#E2C98F] via-[#C5A059] to-[#99793C] text-transparent bg-clip-text drop-shadow-[0px_1px_2px_rgba(0,0,0,0.3)] select-none leading-none\">\n                                \360\235\222\261\360\235\222\261\n                              </div>\n                              <div className=\"h-1.5 w-[1px] bg-gradient-to-b from-[#C5A059]/40 to-transparent mt-0.5\"></div>\n                              <p className=\"text-[5.5px] uppercase tracking-[0.3em] font-serif bg-gradient-to-r from-[#E2C98F] via-[#C5A059] to-[#99793C] text-transparent bg-clip-text font-bold mt-1.5\">\n                                Vellum & Vestige\n                              </p>\n                            </div>\n                          </div>\n                        </div>\n                      ) : (\n                        // OPEN SPREAD MOCKUP\n                        <div className=\"flex flex-col items-center\">\n                          <div className=\"flex w-[340px] md:w-[480px] h-[220px] md:h-[280px] shadow-[40px_35px_65px_-15px_rgba(0,0,0,0.35)] relative bg-[#FCFAF7] border-y border-stone-200\">\n                            \n                            {/* Shadow casting in the center page fold */}\n                            <div className=\"absolute inset-y-0 left-1/2 -translate-x-1/2 w-4 bg-gradient-to-r from-black/10 via-black/25 to-black/10 z-20\"></div>\n\n                            {/* Left Page (Blank heavy cotton texture) */}\n                            <div className=\"w-1/2 h-full bg-[#FCFAF7] p-5 relative border-r border-stone-100 flex flex-col justify-between\">\n                              <div className=\"absolute inset-0 bg-stone-500/5 mix-blend-multiply rounded-l-sm\"></div>\n                              <div className=\"w-8 h-[1px] bg-stone-300\"></div>\n                              <div className=\"space-y-1.5 opacity-30\">\n                                <div className=\"h-1 bg-stone-400 w-1/2\"></div>\n                                <div className=\"h-1 bg-stone-400 w-3/4\"></div>\n                                <div className=\"h-1 bg-stone-400 w-1/3\"></div>\n                              </div>\n                              <span className=\"text-[7px] font-mono tracking-widest text-stone-400\">VELLUM & VESTIGE</span>\n                            </div>\n\n                            {/* Right Page (Contains Heartwarming Editorial Photo) */}\n                            <div className=\"w-1/2 h-full bg-[#FCFAF7] p-4 relative flex flex-col justify-between\">\n                              <div className=\"absolute inset-0 bg-stone-500/5 mix-blend-multiply rounded-r-sm\"></div>\n                              \n                              {/* Inner Styled Photo frame simulating real visualizer */}\n                              <div className=\"flex-1 bg-stone-100 border border-stone-200 rounded-sm relative overflow-hidden flex flex-col justify-center items-center p-2 text-center\">\n                                \n                                {/* Texture filter according to Style (B&W or analog color) */}\n                                <div className={`absolute inset-0 ${\n                                  photoStyle === \"bw\" \n                                    ? \"bg-gradient-to-br from-stone-300 to-stone-500 grayscale\" \n                                    : \"bg-gradient-to-br from-amber-100/40 via-orange-100/30 to-amber-900/10\"\n                                } opacity-40 mix-blend-multiply z-10`}></div>\n\n                                {/* Warm natural sunray on photo */}\n                                <div className=\"absolute top-0 right-0 w-full h-full bg-gradient-to-tr from-transparent via-amber-200/20 to-transparent rotate-12 blur-sm z-10\"></div>\n\n                                {/* Display custom subject graphics/text */}\n                                <div className=\"relative z-10 flex flex-col items-center\">\n                                  <span className=\"text-[8px] uppercase tracking-widest font-mono text-[#1F2022] bg-[#F5F2ED] px-2 py-0.5 shadow-sm rounded-sm\">\n                                    {OPEN_PHOTO_THEMES.find(t => t.id === photoTheme)?.name}\n                                  </span>\n                                  <p className=\"text-[9px] font-serif italic text-stone-700 mt-2 max-w-[140px] leading-tight\">\n                                    \"{OPEN_PHOTO_THEMES.find(t => t.id === photoTheme)?.desc.substring(0, 52)}...\"\n                                  </p>\n                                </div>\n                                \n                                {/* Aesthetic photo camera stamp */}\n                                <div className=\"absolute bottom-1 right-2 text-[6px] text-stone-400 font-mono tracking-tighter\">\n                                  HASSELBLAD 80MM F/2.8\n                                </div>\n                              </div>\n\n                              <div className=\"flex justify-between items-center mt-2.5 text-[7px] font-mono text-stone-400\">\n                                <span>SENSITIVE SERIES COMP</span>\n                                <span>PL. 09</span>\n                              </div>\n                            </div>\n\n                            {/* Visual representation of the colored book cover edges protruding underneath */}\n                            <div \n                              style={{ backgroundColor: SWATCHES.find(s => s.id === swatch)?.hex }} \n                              className=\"absolute bottom-[-4px] left-[2px] right-[2px] h-[4px] shadow-md rounded-b-sm\"\n                            ></div>\n                          </div>\n                          <p className=\"text-[10px] uppercase font-mono mt-3 tracking-widest text-stone-500\">\n                            Open cotton spread: 12\" x 9\" structural proportion\n                          </p>\n                        </div>\n                      )}\n                    </div>\n\n                    {/* Submit and go button for full-stack AI model generation */}\n                    <div className=\"mt-8 flex flex-col items-center\">\n                      <button\n                        onClick={handleGenerateImage}\n                        className=\"flex items-center gap-2 bg-[#1F2022] hover:bg-[#1f2022]/90 text-[#D7CEBE] px-6 py-3.5 rounded text-xs uppercase tracking-widest font-bold shadow-md transition-all hover:scale-[1.03] active:scale-[0.98] cursor-pointer\"\n                      >\n                        <Sparkles className=\"w-4 h-4 text-[#C5A059]\" />\n                        <span>Generate Photorealistic Art</span>\n                      </button>\n                      <p className=\"text-[9px] opacity-60 mt-2 text-center max-w-xs font-serif italic\">\n                        \"Trigger the server-side Imagen core to compile these dynamic materials into a final gallery photograph.\"\n                      </p>\n                    </div>\n                  </>\n                ) : (\n                  /* PHOTO MODE: Loading state, success view, or error view */\n                  <div className=\"w-full max-w-xl bg-[#FAF8F5] p-6 rounded border border-[#1F2022]/10 shadow-lg relative flex flex-col items-center justify-center min-h-[340px] text-center\">\n                    {isGenerating ? (\n                      <div className=\"flex flex-col items-center justify-center text-center p-8\">\n                        {/* Spinning loader */}\n                        <div className=\"w-10 h-10 border-2 border-[#1F2022]/10 border-t-[#C5A059] rounded-full animate-spin mb-6\"></div>\n                        \n                        <p className=\"text-[10px] uppercase tracking-[0.2em] text-[#1F2022]/60 font-semibold mb-2\">\n                          AI Director Rendering Phase\n                        </p>\n                        \n                        <h3 className=\"font-serif italic text-sm text-[#1F2022] animate-pulse duration-[3000ms] min-h-[48px] max-w-md flex items-center justify-center\">\n                          \"{LOADING_QUOTES[loadingQuoteIndex]}\"\n                        </h3>\n                        \n                        <div className=\"w-48 h-[1px] bg-gradient-to-r from-transparent via-[#C5A059]/40 to-transparent mt-4\"></div>\n                        \n                        <p className=\"text-[9px] text-[#1F2022]/40 font-mono mt-3 uppercase tracking-wider\">\n                          Engaged model: gemini-2.5-flash-image\n                        </p>\n                      </div>\n                    ) : generationError ? (\n                      <div className=\"flex flex-col items-center justify-center text-center p-6 max-w-md\">\n                        <div className=\"w-12 h-12 rounded-full bg-red-50 flex items-center justify-center text-red-500 mb-4\">\n                          <HelpCircle className=\"w-6 h-6\" />\n                        </div>\n                        <h3 className=\"font-serif text-lg text-red-950 mb-2 font-bold\">Generation Refused</h3>\n                        <p className=\"text-xs text-red-700/80 mb-6 font-serif italic\">\n                          {generationError}\n                        </p>\n                        <div className=\"flex gap-4\">\n                          <button\n                            onClick={handleGenerateImage}\n                            className=\"bg-[#1F2022] hover:bg-[#1f2022]/90 text-[#D7CEBE] px-4 py-2 rounded text-[10px] uppercase tracking-widest font-bold transition-all cursor-pointer\"\n                          >\n                            Retry Generation\n                          </button>\n                          <button\n                            onClick={() => setViewMode(\"draft\")}\n                            className=\"bg-stone-200 hover:bg-stone-300 text-stone-700 px-4 py-2 rounded text-[10px] uppercase tracking-widest font-bold transition-all cursor-pointer\"\n                          >\n                            Back to Draft\n                          </button>\n                        </div>\n                      </div>\n                    ) : generatedImageUrl ? (\n                      <div className=\"flex flex-col items-center w-full\">\n                        {/* The beautiful generated photorealistic artwork */}\n                        <div className=\"relative border-4 border-white shadow-2xl rounded-sm overflow-hidden bg-stone-100 max-h-[300px] flex items-center justify-center select-none\">\n                          <img\n                            src={generatedImageUrl}\n                            alt=\"Vellum & Vestige Generated Artwork Mockup\"\n                            referrerPolicy=\"no-referrer\"\n                            className=\"max-h-[290px] object-contain transition-all duration-500 hover:scale-105\"\n                          />\n                          <div className=\"absolute top-2 right-2 bg-black/60 text-[#D7CEBE] text-[8px] px-2 py-0.5 rounded backdrop-blur-sm uppercase tracking-widest font-mono\">\n                            {PLATFORMS.find(p => p.id === platform)?.ratio} Art\n                          </div>\n                        </div>\n\n                        {/* Controls */}\n                        <div className=\"flex gap-4 mt-6\">\n                          <a\n                            href={generatedImageUrl}\n                            download={`vellum_vestige_${selectedVolume}.png`}\n                            className=\"bg-[#1F2022] hover:bg-[#1f2022]/90 text-[#D7CEBE] px-4 py-2 rounded text-[10px] uppercase tracking-widest font-bold transition-all hover:scale-105 cursor-pointer flex items-center gap-1.5\"\n                          >\n                            Download Masterpiece\n                          </a>\n                          <button\n                            onClick={() => setViewMode(\"draft\")}\n                            className=\"bg-stone-200 hover:bg-stone-300 text-stone-700 px-4 py-2 rounded text-[10px] uppercase tracking-widest font-bold transition-all cursor-pointer\"\n                          >\n                            Modify Settings\n                          </button>\n                        </div>\n\n                        <p className=\"text-[9px] text-[#1F2022]/50 font-serif italic mt-3 text-center max-w-sm\">\n                          \"Successfully compiled by Google GenAI. Note: you can use \'Modify Settings\' to alter cover, materials, backdrop or themes, and generate a new photorealistic photo.\"\n                        </p>\n                      </div>\n                    ) : (\n                      <div className=\"flex flex-col items-center justify-center text-center p-8\">\n                        <Sparkles className=\"w-10 h-10 text-[#C5A059] mb-4 animate-pulse\" />\n                        <h3 className=\"font-serif text-base text-[#1F2022] mb-1 font-bold\">Unrendered Masterpiece</h3>\n                        <p className=\"text-xs text-stone-500 font-serif italic mb-6 max-w-xs\">\n                          No masterpiece has been rendered yet. Click below to compile your settings.\n                        </p>\n                        <button\n                          onClick={handleGenerateImage}\n                          className=\"bg-[#1F2022] hover:bg-[#1F2022]/90 text-[#D7CEBE] px-5 py-2.5 rounded text-[10px] uppercase tracking-widest font-bold transition-all cursor-pointer\"\n                        >\n                          Generate Now\n                        </button>\n                      </div>\n                    )}\n                  </div>\n                )}"
      }
      num_matches: 1
    }
  }
}

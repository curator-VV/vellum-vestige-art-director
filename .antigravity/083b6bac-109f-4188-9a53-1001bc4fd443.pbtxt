    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState, useEffect } from \"react\";\nimport { \n  Sparkles, \n  Copy, \n  Check, \n  BookOpen, \n  FileText, \n  Image as ImageIcon, \n  RefreshCw, \n  Instagram, \n  Layers, \n  Compass, \n  Sliders, \n  Info, \n  Sunset, \n  BookMarked,\n  HelpCircle,\n  Eye\n} from \"lucide-react\";\n\n// Brand constants from Vellum & Vestige guidelines\nconst SWATCHES = [\n  { id: \"ink\", name: \"Ink\", hex: \"#1F2022\", desc: \"Deep off-black\", textLight: true },\n  { id: \"echo\", name: \"Echo\", hex: \"#232D42\", desc: \"Muted architectural navy\", textLight: true },\n  { id: \"haze\", name: \"Haze\", hex: \"#D4D7D9\", desc: \"Muted grey-blue stone\", textLight: false },\n  { id: \"parchment\", name: \"Parchment\", hex: \"#D7CEBE\", desc: \"Warm, organic beige\", textLight: false }\n];\n\nconst MATERIALS = [\n  { id: \"linen\", name: \"European Flax Linen\", desc: \"Premium European flax linen with a distinct tactile weave\" },\n  { id: \"leather\", name: \"Italian Full-Grain Leather\", desc: \"Authentic Italian full-grain leather with natural grain articulation\" }\n];\n\nconst PLATFORMS = [\n  { id: \"ig_post_sq\", name: \"Instagram Post (Square)\", sub: \"Square layout\", ratio: \"1:1\", token: \"[--ar 1:1]\" },\n  { id: \"ig_post_pt\", name: \"Instagram Post (Portrait)\", sub: \"Classic portrait\", ratio: \"4:5\", token: \"[--ar 4:5]\" },\n  { id: \"ig_story\", name: \"Instagram Story\", sub: \"Exact vertical framing\", ratio: \"9:16\", token: \"[--ar 9:16]\" },\n  { id: \"ig_reel\", name: \"Instagram Reel / TikTok\", sub: \"Cinematic vertical stills\", ratio: \"9:16\", token: \"[--ar 9:16]\" }\n];\n\nconst OPEN_PHOTO_THEMES = [\n  { id: \"family\", name: \"Family Bonds\", desc: \"Heartwarming scenes of family connections and gatherings\" },\n  { id: \"relationships\", name: \"Profound Relationships\", desc: \"Emotional portraits of couples or dear friends\" },\n  { id: \"beginnings\", name: \"New Beginnings\", desc: \"Capturing hope, fresh starts, and intimate life shifts\" },\n  { id: \"homes\", name: \"Welcoming New Homes\", desc: \"Sunlit interiors, architectural details, and homeliness\" },\n  { id: \"grandparents\", name: \"Grandparents Sharing Stories\", desc: \"Generational storytelling, rich textures, and wisdom\" },\n  { id: \"pets\", name: \"Household Pets\", desc: \"Intimate and endearing frames of beloved pets in home light\" }\n];\n\nconst BACKDROPS = [\n  { id: \"concrete\", name: \"Grey Concrete Slab\", desc: \"Raw, minimalist grey concrete slab with natural pitting\" },\n  { id: \"slate\", name: \"Dark Slate Block\", desc: \"Textured, dark architectural slate blocks\" },\n  { id: \"linen_sheet\", name: \"Coarse Unbleached Linen\", desc: \"Natural unbleached linen sheet with rich organic wrinkles\" },\n  { id: \"custom\", name: \"Custom Workspace...\", desc: \"Write your own premium minimalist environment\" }\n];\n\nconst PHOTO_STYLES = [\n  { id: \"analog_color\", name: \"Analog Warm Color\", desc: \"Authentic, rich, warm-toned analog color film photography\" },\n  { id: \"bw\", name: \"Crisp Black & White\", desc: \"Timeless black and white photography with deep rich contrasts\" }\n];\n\nexport default function App() {\n  // State for the prompt configurations\n  const [platform, setPlatform] = useState(\"ig_post_pt\");\n  const [swatch, setSwatch] = useState(\"ink\");\n  const [material, setMaterial] = useState(\"linen\");\n  const [state, setState] = useState(\"closed\"); // \"closed\" | \"open\"\n  const [backdrop, setBackdrop] = useState(\"concrete\");\n  const [customBackdrop, setCustomBackdrop] = useState(\"raw volcanic basalt block, matte earthy finish\");\n  const [aestheticStyle, setAestheticStyle] = useState(\"Quiet luxury editorial, high-end design journal mood, minimalist and pure\");\n  const [photoTheme, setPhotoTheme] = useState(\"family\");\n  const [photoStyle, setPhotoStyle] = useState(\"analog_color\");\n  \n  // Custom user requested toggles\n  const [logoPosition, setLogoPosition] = useState(\"brand_default\"); // \"brand_default\" (upper third) | \"user_centered_bottom\" (bottom centered)\n  const [includeProps, setIncludeProps] = useState(true);\n  const [customProps, setCustomProps] = useState(\"A single dried silver dollar eucalyptus branch casting a soft shadow\");\n  const [copied, setCopied] = useState(false);\n  const [activeTab, setActiveTab] = useState(\"prompt_engine\"); // \"prompt_engine\" | \"brand_guide\" | \"visual_director\"\n\n  // Generated text prompt calculation\n  const getCompiledPrompt = () => {\n    const selectedSwatch = SWATCHES.find(s => s.id === swatch) || SWATCHES[0];\n    const selectedMaterial = MATERIALS.find(m => m.id === material) || MATERIALS[0];\n    const selectedPlatform = PLATFORMS.find(p => p.id === platform) || PLATFORMS[0];\n    \n    // Base book configuration\n    let promptParts = [];\n    \n    // Core physical book attributes\n    promptParts.push(`A premium 12\"x9\" portrait monograph published by Vellum & Vestige`);\n    \n    if (state === \"closed\") {\n      promptParts.push(`featuring a thick, substantial, high-density book block with premium layered deckle textured edges`);\n      promptParts.push(`bound in a pristine ${selectedSwatch.name} (${selectedSwatch.hex}) cover made of ${selectedMaterial.desc}`);\n      promptParts.push(`The spine of the book is completely blank, smooth, and solid-toned cover material with zero printing, text, or markings`);\n      \n      // Stamp location override\n      if (logoPosition === \"user_centered_bottom\") {\n        promptParts.push(`An elegant \'VV\' calligraphic monogram hallmark is deeply blind-debossed and hot-stamped with genuine gold foil leaf, perfectly centered and positioned near the bottom-third of the front cover`);\n      } else {\n        promptParts.push(`The centered \'VV\' monogram hallmark is deeply blind-debossed and hot-stamped with genuine gold foil leaf, positioned on the upper-third of the front cover`);\n      }\n    } else {\n      // Open Spread configuration\n      const selectedTheme = OPEN_PHOTO_THEMES.find(t => t.id === photoTheme) || OPEN_PHOTO_THEMES[0];\n      const selectedPhotoStyle = PHOTO_STYLES.find(s => s.id === photoStyle) || PHOTO_STYLES[0];\n      \n      promptParts.push(`presented as an open spread monograph displaying thick, heavy deckled cotton pages in warm parchment white (#FCFAF7)`);\n      promptParts.push(`On the open pages is a professional, high-end editorial photograph capturing ${selectedTheme.desc}`);\n      promptParts.push(`The photograph is rendered with an intentional, happy, and heartwarming tone in ${selectedPhotoStyle.desc}`);\n      promptParts.push(`The thick edges of the book block underneath show the luxurious ${selectedSwatch.name} tone of the cover material (${selectedSwatch.hex}) resting flat on the surface`);\n    }\n\n    // Atmospheric Sunlight rules\n    promptParts.push(`Natural daylight-balanced illumination with sharp, defined diagonal rays of morning sunlight casting long geometric shadows from the side, beautifully catching the tactile grain of the cover and the rich paper texture`);\n\n    // Surface and environment\n    const selectedBackdrop = BACKDROPS.find(b => b.id === backdrop) || BACKDROPS[0];\n    const surfaceText = selectedBackdrop.id === \"custom\" ? customBackdrop : selectedBackdrop.desc;\n    promptParts.push(`The volume is grounded upon a raw, minimalist ${surfaceText}`);\n    \n    if (includeProps && customProps) {\n      promptParts.push(`with ${customProps} styled nearby on the slab`);\n    }\n\n    // Aesthetic style\n    if (aestheticStyle) {\n      promptParts.push(`${aestheticStyle}`);\n    }\n\n    // Append aspect ratio token at the very end\n    const finalPrompt = promptParts.join(\". \") + `. ${selectedPlatform.token}`;\n    return finalPrompt;\n  };\n\n  // Compile the short 3-bullet ledger\n  const getLedger = () => {\n    const selectedSwatch = SWATCHES.find(s => s.id === swatch) || SWATCHES[0];\n    const selectedPlatform = PLATFORMS.find(p => p.id === platform) || PLATFORMS[0];\n    return {\n      swatch: `${selectedSwatch.name} Swatch (${selectedSwatch.hex})`,\n      platform: `${selectedPlatform.name} (${selectedPlatform.ratio})`,\n      state: state === \"closed\" ? \"Closed Monograph\" : \"Open Spread Comp\"\n    };\n  };\n\n  const handleCopy = () => {\n    const compiled = getCompiledPrompt();\n    const ledger = getLedger();\n    const markdownOutput = `\\`\\`\\`markdown\\n${compiled}\\n\\`\\`\\`\\n\\n- **Swatch**: ${ledger.swatch}\\n- **Format**: ${ledger.platform}\\n- **State**: ${ledger.state}`;\n    \n    navigator.clipboard.writeText(markdownOutput);\n    setCopied(true);\n    setTimeout(() => setCopied(false), 2000);\n  };\n\n  return (\n    <div id=\"vv-app-root\" className=\"bg-[#F5F2ED] text-[#1F2022] font-sans min-h-screen flex flex-col antialiased\">\n      {/* Top Banner Warning regarding Frame constraints */}\n      <div className=\"bg-[#1F2022] text-[#D7CEBE] text-center text-[10px] uppercase tracking-widest py-1.5 px-4 border-b border-[#1F2022]/20 flex justify-between items-center\">\n        <span>Vellum & Vestige Visual Core Engine v2.1</span>\n        <span className=\"opacity-75\">Brand Guidelines Compliant</span>\n      </div>\n\n      {/* Header Navigation */}\n      <header className=\"border-b border-[#1F2022]/10 px-6 md:px-12 py-5 flex flex-col sm:flex-row justify-between items-center sm:items-end gap-4 bg-[#F5F2ED]\">\n        <div>\n          <h1 className=\"text-3xl font-serif tracking-tight leading-none uppercase text-center sm:text-left\">\n            Vellum & Vestige\n          </h1>\n          <p className=\"text-[10px] tracking-[0.2em] uppercase mt-2 opacity-60 text-center sm:text-left\">\n            Content Director & Visual Art Engine\n          </p>\n        </div>\n        <div className=\"flex gap-6 text-[11px] uppercase tracking-widest font-semibold\">\n          <button \n            id=\"tab-prompt\"\n            onClick={() => setActiveTab(\"prompt_engine\")}\n            className={`pb-1 transition-all ${activeTab === \"prompt_engine\" ? \"border-b border-[#1F2022] text-[#1F2022]\" : \"opacity-40 hover:opacity-80\"}`}\n          >\n            Prompt Engine\n          </button>\n          <button \n            id=\"tab-brand\"\n            onClick={() => setActiveTab(\"brand_guide\")}\n            className={`pb-1 transition-all ${activeTab === \"brand_guide\" ? \"border-b border-[#1F2022] text-[#1F2022]\" : \"opacity-40 hover:opacity-80\"}`}\n          >\n            Brand Guide\n          </button>\n          <button \n            id=\"tab-director\"\n            onClick={() => setActiveTab(\"visual_director\")}\n            className={`pb-1 transition-all ${activeTab === \"visual_director\" ? \"border-b border-[#1F2022] text-[#1F2022]\" : \"opacity-40 hover:opacity-80\"}`}\n          >\n            Director Notes\n          </button>\n        </div>\n      </header>\n\n      {/* Main Container */}\n      <div className=\"flex-1 flex flex-col lg:flex-row overflow-hidden\">\n        \n        {/* TAB 1: Main Interactive Form / Prompt Engine */}\n        {activeTab === \"prompt_engine\" && (\n          <>\n            {/* Sidebar Controls */}\n            <section className=\"w-full lg:w-[420px] border-r border-[#1F2022]/10 p-6 md:p-8 flex flex-col gap-6 bg-[#FAF8F5] overflow-y-auto\">\n              \n              {/* Distribution Channel & Size Routing */}\n              <div>\n                <label className=\"text-[10px] uppercase tracking-widest opacity-60 block mb-2.5 font-semibold flex items-center justify-between\">\n                  <span>Distribution Channel</span>\n                  <span className=\"text-[9px] bg-[#1F2022]/5 px-1.5 py-0.5 rounded font-mono\">Section I</span>\n                </label>\n                <div className=\"grid grid-cols-2 gap-2\">\n                  {PLATFORMS.map((p) => (\n                    <button\n                      key={p.id}\n                      id={`platform-btn-${p.id}`}\n                      onClick={() => setPlatform(p.id)}\n                      className={`border p-2.5 text-left transition-all relative rounded-sm ${\n                        platform === p.id\n                          ? \"border-[#1F2022] bg-[#1F2022] text-[#D7CEBE]\"\n                          : \"border-[#1F2022]/20 hover:bg-[#1F2022]/5 text-[#1F2022]\"\n                      }`}\n                    >\n                      <div className=\"text-[10px] uppercase tracking-wider font-semibold\">{p.name}</div>\n                      <div className=\"text-[9px] opacity-70 font-mono mt-0.5\">{p.ratio} \342\200\242 {p.token}</div>\n                    </button>\n                  ))}\n                </div>\n              </div>\n\n              {/* Cover Materials & Authorized Swatches */}\n              <div>\n                <label className=\"text-[10px] uppercase tracking-widest opacity-60 block mb-2.5 font-semibold flex items-center justify-between\">\n                  <span>Cover Material & Swatch</span>\n                  <span className=\"text-[9px] bg-[#1F2022]/5 px-1.5 py-0.5 rounded font-mono\">Section II</span>\n                </label>\n                \n                {/* Material Selection */}\n                <div className=\"flex gap-4 mb-3\">\n                  {MATERIALS.map((m) => (\n                    <button\n                      key={m.id}\n                      id={`material-btn-${m.id}`}\n                      onClick={() => setMaterial(m.id)}\n                      className={`flex items-center gap-2 cursor-pointer text-left focus:outline-none transition-all ${\n                        material === m.id ? \"opacity-100 font-semibold\" : \"opacity-40 hover:opacity-75\"\n                      }`}\n                    >\n                      <span className={`w-3 h-3 rounded-full border border-[#1F2022] flex items-center justify-center`}>\n                        {material === m.id && <span className=\"w-1.5 h-1.5 rounded-full bg-[#1F2022]\"></span>}\n                      </span>\n                      <span className=\"text-[11px] uppercase tracking-wider\">{m.name}</span>\n                    </button>\n                  ))}\n                </div>\n\n                {/* Swatch Colors Grid */}\n                <div className=\"grid grid-cols-4 gap-2\">\n                  {SWATCHES.map((s) => (\n                    <button\n                      key={s.id}\n                      id={`swatch-btn-${s.id}`}\n                      onClick={() => setSwatch(s.id)}\n                      style={{ backgroundColor: s.hex }}\n                      className={`aspect-square rounded transition-all focus:outline-none relative group ${\n                        swatch === s.id \n                          ? \"ring-2 ring-offset-2 ring-[#1F2022] border-white scale-[1.03]\" \n                          : \"opacity-80 hover:opacity-100 border border-[#1F2022]/10\"\n                      }`}\n                      title={`${s.name} - ${s.desc}`}\n                    >\n                      <span className={`absolute bottom-1 right-1.5 text-[8px] font-semibold tracking-tighter ${\n                        s.textLight ? \"text-white/80\" : \"text-[#1F2022]/80\"\n                      }`}>\n                        {s.name[0]}\n                      </span>\n                    </button>\n                  ))}\n                </div>\n                <div className=\"flex justify-between items-center mt-2 font-serif text-[10px] opacity-60 italic\">\n                  <span>Current: <span className=\"font-semibold text-[#1F2022] uppercase\">{swatch}</span></span>\n                  <span>{SWATCHES.find(s => s.id === swatch)?.hex}</span>\n                </div>\n              </div>\n\n              {/* Open vs Closed Spread Direction */}\n              <div>\n                <label className=\"text-[10px] uppercase tracking-widest opacity-60 block mb-2.5 font-semibold flex items-center justify-between\">\n                  <span>Physical State / Spread</span>\n                  <span className=\"text-[9px] bg-[#1F2022]/5 px-1.5 py-0.5 rounded font-mono\">Section III</span>\n                </label>\n                <div className=\"grid grid-cols-2 gap-2\">\n                  <button\n                    id=\"state-closed-btn\"\n                    onClick={() => setState(\"closed\")}\n                    className={`border p-2.5 text-center transition-all uppercase text-[10px] tracking-widest font-bold rounded-sm ${\n                      state === \"closed\"\n                        ? \"border-[#1F2022] bg-[#1F2022] text-[#D7CEBE]\"\n                        : \"border-[#1F2022]/20 hover:bg-[#1F2022]/5\"\n                    }`}\n                  >\n                    Closed Cover\n                  </button>\n                  <button\n                    id=\"state-open-btn\"\n                    onClick={() => setState(\"open\")}\n                    className={`border p-2.5 text-center transition-all uppercase text-[10px] tracking-widest font-bold rounded-sm ${\n                      state === \"open\"\n                        ? \"border-[#1F2022] bg-[#1F2022] text-[#D7CEBE]\"\n                        : \"border-[#1F2022]/20 hover:bg-[#1F2022]/5\"\n                    }`}\n                  >\n                    Open Spread\n                  </button>\n                </div>\n              </div>\n\n              {/* Dynamic Sub-Form depending on State */}\n              {state === \"closed\" ? (\n                <div className=\"space-y-4 p-4 border border-[#1F2022]/10 bg-[#1F2022]/5 rounded-sm\">\n                  <div className=\"flex items-center justify-between text-[10px] uppercase tracking-wider font-bold mb-1 opacity-70\">\n                    <span>Closed Cover Parameters</span>\n                    <Sliders className=\"w-3.5 h-3.5\" />\n                  </div>\n\n                  {/* Logo Hallmark Stamp Position Options */}\n                  <div>\n                    <div className=\"flex justify-between items-center mb-1.5\">\n                      <label className=\"text-[9px] uppercase tracking-wider font-semibold text-[#1F2022]/80\">\n                        Foil Logo Hallmark Position\n                      </label>\n                      <span className=\"text-[8px] bg-[#C5A059]/10 text-[#C5A059] px-1 rounded\">Embossed</span>\n                    </div>\n                    <select\n                      id=\"logo-position-select\"\n                      value={logoPosition}\n                      onChange={(e) => setLogoPosition(e.target.value)}\n                      className=\"w-full bg-[#FAF8F5] border border-[#1F2022]/20 rounded p-1.5 text-xs focus:outline-none\"\n                    >\n                      <option value=\"brand_default\">V&V Master Guide: Upper-Third Stamp</option>\n                      <option value=\"user_centered_bottom\">Custom Layout: Bottom-Centered Stamp</option>\n                    </select>\n                    <p className=\"text-[9px] mt-1 text-[#1F2022]/60 italic font-serif\">\n                      {logoPosition === \"user_centered_bottom\" \n                        ? \"Your request: Centered near the bottom with an elegant, gold-embossed finish.\"\n                        : \"Vellum & Vestige Brand Standard: Deeply blind-debossed upper-third stamp.\"}\n                    </p>\n                  </div>\n                </div>\n              ) : (\n                <div className=\"space-y-4 p-4 border border-[#1F2022]/10 bg-[#1F2022]/5 rounded-sm\">\n                  <div className=\"flex items-center justify-between text-[10px] uppercase tracking-wider font-bold mb-1 opacity-70\">\n                    <span>Open spread photography options</span>\n                    <BookOpen className=\"w-3.5 h-3.5\" />\n                  </div>\n\n                  {/* Curated Happy & Heartwarming Photo Themes */}\n                  <div>\n                    <label className=\"text-[9px] uppercase tracking-wider font-semibold text-[#1F2022]/80 block mb-1\">\n                      Heartwarming Photo Subject\n                    </label>\n                    <select\n                      id=\"photo-theme-select\"\n                      value={photoTheme}\n                      onChange={(e) => setPhotoTheme(e.target.value)}\n                      className=\"w-full bg-[#FAF8F5] border border-[#1F2022]/20 rounded p-1.5 text-xs focus:outline-none\"\n                    >\n                      {OPEN_PHOTO_THEMES.map(theme => (\n                        <option key={theme.id} value={theme.id}>{theme.name} \342\200\224 {theme.desc.substring(0, 32)}...</option>\n                      ))}\n                    </select>\n                  </div>\n\n                  {/* Photography Style (B&W vs warm Analog) */}\n                  <div>\n                    <label className=\"text-[9px] uppercase tracking-wider font-semibold text-[#1F2022]/80 block mb-1\">\n                      Analog Color Tone\n                    </label>\n                    <div className=\"grid grid-cols-2 gap-2\">\n                      {PHOTO_STYLES.map(style => (\n                        <button\n                          key={style.id}\n                          id={`photo-style-${style.id}`}\n                          onClick={() => setPhotoStyle(style.id)}\n                          className={`border p-1.5 text-[10px] uppercase tracking-wider rounded transition-all ${\n                            photoStyle === style.id \n                              ? \"bg-[#1F2022] text-[#D7CEBE] border-[#1F2022]\" \n                              : \"bg-[#FAF8F5] text-[#1F2022] border-[#1F2022]/20 hover:bg-[#1F2022]/5\"\n                          }`}\n                        >\n                          {style.name.split(\" \")[0]}\n                        </button>\n                      ))}\n                    </div>\n                  </div>\n                </div>\n              )}\n\n              {/* Surface Workspace Background options */}\n              <div>\n                <label className=\"text-[10px] uppercase tracking-widest opacity-60 block mb-2 font-semibold\">\n                  Backdrop Workspace Surface\n                </label>\n                <div className=\"grid grid-cols-2 gap-2\">\n                  {BACKDROPS.map((b) => (\n                    <button\n                      key={b.id}\n                      id={`backdrop-btn-${b.id}`}\n                      onClick={() => setBackdrop(b.id)}\n                      className={`border p-2 text-left rounded-sm transition-all ${\n                        backdrop === b.id\n                          ? \"border-[#1F2022] bg-[#1F2022]/5 font-semibold\"\n                          : \"border-[#1F2022]/10 hover:bg-[#1F2022]/5\"\n                      }`}\n                    >\n                      <div className=\"text-[10px] uppercase tracking-tight\">{b.name}</div>\n                    </button>\n                  ))}\n                </div>\n\n                {backdrop === \"custom\" && (\n                  <div className=\"mt-2.5\">\n                    <input\n                      id=\"custom-backdrop-input\"\n                      type=\"text\"\n                      value={customBackdrop}\n                      onChange={(e) => setCustomBackdrop(e.target.value)}\n                      className=\"w-full bg-[#1F2022]/5 p-2 text-xs font-serif italic border-b border-[#1F2022]/30 focus:outline-none focus:border-[#1F2022]\"\n                      placeholder=\"e.g. rough textured grey-beige limestone block\"\n                    />\n                  </div>\n                )}\n              </div>\n\n              {/* Additional Aesthetic Style refinement */}\n              <div>\n                <label className=\"text-[10px] uppercase tracking-widest opacity-60 block mb-1.5 font-semibold\">\n                  Desired Aesthetic Style\n                </label>\n                <input\n                  id=\"aesthetic-style-input\"\n                  type=\"text\"\n                  value={aestheticStyle}\n                  onChange={(e) => setAestheticStyle(e.target.value)}\n                  className=\"w-full bg-[#FAF8F5] border border-[#1F2022]/10 rounded p-2 text-xs font-serif italic focus:outline-none focus:ring-1 focus:ring-[#1F2022]\"\n                  placeholder=\"e.g. Quiet luxury editorial, minimalist, warm natural ambient mood...\"\n                />\n              </div>\n\n              {/* Styling props option */}\n              <div className=\"space-y-2 pt-2 border-t border-[#1F2022]/10\">\n                <div className=\"flex items-center justify-between\">\n                  <label className=\"text-[10px] uppercase tracking-widest opacity-60 font-semibold flex items-center gap-1\">\n                    <span>Incorporate Styling Props</span>\n                  </label>\n                  <input\n                    id=\"include-props-checkbox\"\n                    type=\"checkbox\"\n                    checked={includeProps}\n                    onChange={(e) => setIncludeProps(e.target.checked)}\n                    className=\"rounded border-[#1F2022]/30 accent-[#1F2022] w-3.5 h-3.5\"\n                  />\n                </div>\n                {includeProps && (\n                  <input\n                    id=\"custom-props-input\"\n                    type=\"text\"\n                    value={customProps}\n                    onChange={(e) => setCustomProps(e.target.value)}\n                    className=\"w-full bg-[#FAF8F5] border border-[#1F2022]/10 rounded p-2 text-xs font-serif italic focus:outline-none\"\n                    placeholder=\"e.g. A single raw brass bookmark casting a geometric shadow\"\n                  />\n                )}\n              </div>\n\n            </section>\n\n            {/* Visualizer & Code Output Panel */}\n            <section className=\"flex-1 bg-[#EBE8E3] p-6 md:p-10 flex flex-col justify-between overflow-y-auto\">\n              \n              {/* Preview Canvas */}\n              <div className=\"flex-1 relative flex flex-col items-center justify-center min-h-[380px] py-6\">\n                \n                {/* Visual Director Floating Note */}\n                <div className=\"absolute top-0 right-0 max-w-xs text-[10px] leading-relaxed bg-[#F5F2ED]/90 p-3.5 border border-[#1F2022]/10 shadow-sm backdrop-blur-sm rounded-sm hidden sm:block\">\n                  <p className=\"font-bold uppercase mb-1 tracking-tighter text-[#1F2022] flex items-center gap-1\">\n                    <Eye className=\"w-3.5 h-3.5 text-[#C5A059]\" />\n                    <span>Visual Director Notes:</span>\n                  </p>\n                  <p className=\"font-serif italic text-[#1F2022]/80\">\n                    \"Ensure the gold foil stamp catches the morning daylight angle. Edge material edges must feel authentically layered and deckled.\"\n                  </p>\n                </div>\n\n                {/* Main Book Interactive Mockup (Closed / Open) */}\n                <div className=\"relative group transition-all duration-300\">\n                  {state === \"closed\" ? (\n                    // CLOSED MONOGRAPH MOCKUP\n                    <div \n                      id=\"book-mockup-closed\"\n                      style={{ \n                        backgroundColor: SWATCHES.find(s => s.id === swatch)?.hex,\n                        boxShadow: \"30px 40px 65px -15px rgba(0,0,0,0.45), inset -2px -2px 10px rgba(255,255,255,0.05)\"\n                      }} \n                      className=\"w-60 h-[320px] relative flex flex-col justify-between p-6 transition-all duration-500 rounded-sm border border-black/10\"\n                    >\n                      {/* Spine detail effect */}\n                      <div className=\"absolute inset-y-0 left-0 w-2.5 bg-gradient-to-r from-black/25 via-transparent to-transparent\"></div>\n                      <div className=\"absolute inset-y-0 left-2.5 w-[1px] bg-white/5\"></div>\n                      \n                      {/* Linen/Leather tactile textures */}\n                      {material === \"linen\" ? (\n                        <div className=\"absolute inset-0 opacity-15 pointer-events-none mix-blend-overlay bg-[radial-gradient(#1f2022_1px,transparent_1px)] [background-size:3px_3px]\"></div>\n                      ) : (\n                        <div className=\"absolute inset-0 opacity-10 pointer-events-none mix-blend-soft-light bg-[radial-gradient(circle,rgba(255,255,255,0.15)_10%,transparent_20%)] [background-size:5px_5px]\"></div>\n                      )}\n\n                      {/* Directional Sunlight simulation overlay */}\n                      <div className=\"absolute inset-0 pointer-events-none overflow-hidden rounded-sm\">\n                        <div className=\"absolute -left-1/3 top-0 w-[200%] h-full bg-gradient-to-tr from-transparent via-white/10 to-transparent rotate-[25deg] translate-x-12 translate-y-12 blur-md\"></div>\n                      </div>\n\n                      {/* Logo stamp top position */}\n                      {logoPosition === \"brand_default\" && (\n                        <div className=\"flex flex-col items-center mt-12 opacity-95 animate-pulse-slow\">\n                          <div className=\"border border-[#C5A059]/50 p-2.5 bg-gradient-to-br from-[#E2C98F] via-[#C5A059] to-[#99793C] text-transparent bg-clip-text font-serif text-3xl font-bold tracking-tighter select-none shadow-[0px_2px_4px_rgba(0,0,0,0.3)]\">\n                            VV\n                          </div>\n                          <div className=\"h-14 w-[1px] bg-gradient-to-b from-[#C5A059]/40 to-transparent mt-2\"></div>\n                        </div>\n                      )}\n\n                      {/* Empty spacer / Middle content */}\n                      <div></div>\n\n                      {/* Cover Details Bottom */}\n                      <div className=\"relative z-10 text-center\">\n                        {logoPosition === \"user_centered_bottom\" && (\n                          <div className=\"flex flex-col items-center mb-5 opacity-95\">\n                            <div className=\"border border-[#C5A059]/50 p-2.5 bg-gradient-to-br from-[#E2C98F] via-[#C5A059] to-[#99793C] text-transparent bg-clip-text font-serif text-3xl font-bold tracking-tighter select-none shadow-[0px_2px_4px_rgba(0,0,0,0.3)]\">\n                              VV\n                            </div>\n                            <div className=\"h-4 w-[1px] bg-gradient-to-b from-[#C5A059]/40 to-transparent mt-1\"></div>\n                          </div>\n                        )}\n                        <div className=\"h-px bg-white/10 w-full mb-2\"></div>\n                        <p className={`text-[7.5px] uppercase tracking-[0.4em] text-center ${\n                          SWATCHES.find(s => s.id === swatch)?.textLight ? \"text-white/40\" : \"text-black/40\"\n                        }`}>\n                          Master Series Volume I\n                        </p>\n                      </div>\n                    </div>\n                  ) : (\n                    // OPEN SPREAD MOCKUP\n                    <div className=\"flex flex-col items-center\">\n                      <div className=\"flex w-[340px] md:w-[480px] h-[220px] md:h-[280px] shadow-[40px_35px_65px_-15px_rgba(0,0,0,0.35)] relative bg-[#FCFAF7] border-y border-stone-200\">\n                        \n                        {/* Shadow casting in the center page fold */}\n                        <div className=\"absolute inset-y-0 left-1/2 -translate-x-1/2 w-4 bg-gradient-to-r from-black/10 via-black/25 to-black/10 z-20\"></div>\n\n                        {/* Left Page (Blank heavy cotton texture) */}\n                        <div className=\"w-1/2 h-full bg-[#FCFAF7] p-5 relative border-r border-stone-100 flex flex-col justify-between\">\n                          <div className=\"absolute inset-0 bg-stone-500/5 mix-blend-multiply rounded-l-sm\"></div>\n                          <div className=\"w-8 h-[1px] bg-stone-300\"></div>\n                          <div className=\"space-y-1.5 opacity-30\">\n                            <div className=\"h-1 bg-stone-400 w-1/2\"></div>\n                            <div className=\"h-1 bg-stone-400 w-3/4\"></div>\n                            <div className=\"h-1 bg-stone-400 w-1/3\"></div>\n                          </div>\n                          <span className=\"text-[7px] font-mono tracking-widest text-stone-400\">VELLUM & VESTIGE</span>\n                        </div>\n\n                        {/* Right Page (Contains Heartwarming Editorial Photo) */}\n                        <div className=\"w-1/2 h-full bg-[#FCFAF7] p-4 relative flex flex-col justify-between\">\n                          <div className=\"absolute inset-0 bg-stone-500/5 mix-blend-multiply rounded-r-sm\"></div>\n                          \n                          {/* Inner Styled Photo frame simulating real visualizer */}\n                          <div className=\"flex-1 bg-stone-100 border border-stone-200 rounded-sm relative overflow-hidden flex flex-col justify-center items-center p-2 text-center\">\n                            \n                            {/* Texture filter according to Style (B&W or analog color) */}\n                            <div className={`absolute inset-0 ${\n                              photoStyle === \"bw\" \n                                ? \"bg-gradient-to-br from-stone-300 to-stone-500 grayscale\" \n                                : \"bg-gradient-to-br from-amber-100/40 via-orange-100/30 to-amber-900/10\"\n                            } opacity-40 mix-blend-multiply z-10`}></div>\n\n                            {/* Warm natural sunray on photo */}\n                            <div className=\"absolute top-0 right-0 w-full h-full bg-gradient-to-tr from-transparent via-amber-200/20 to-transparent rotate-12 blur-sm z-10\"></div>\n\n                            {/* Display custom subject graphics/text */}\n                            <div className=\"relative z-10 flex flex-col items-center\">\n                              <span className=\"text-[8px] uppercase tracking-widest font-mono text-[#1F2022] bg-[#F5F2ED] px-2 py-0.5 shadow-sm rounded-sm\">\n                                {OPEN_PHOTO_THEMES.find(t => t.id === photoTheme)?.name}\n                              </span>\n                              <p className=\"text-[9px] font-serif italic text-stone-700 mt-2 max-w-[140px] leading-tight\">\n                                \"{OPEN_PHOTO_THEMES.find(t => t.id === photoTheme)?.desc.substring(0, 52)}...\"\n                              </p>\n                            </div>\n                            \n                            {/* Aesthetic photo camera stamp */}\n                            <div className=\"absolute bottom-1 right-2 text-[6px] text-stone-400 font-mono tracking-tighter\">\n                              HASSELBLAD 80MM F/2.8\n                            </div>\n                          </div>\n\n                          <div className=\"flex justify-between items-center mt-2.5 text-[7px] font-mono text-stone-400\">\n                            <span>SENSITIVE SERIES COMP</span>\n                            <span>PL. 09</span>\n                          </div>\n                        </div>\n\n                        {/* Visual representation of the colored book cover edges protruding underneath */}\n                        <div \n                          style={{ backgroundColor: SWATCHES.find(s => s.id === swatch)?.hex }} \n                          className=\"absolute bottom-[-4px] left-[2px] right-[2px] h-[4px] shadow-md rounded-b-sm\"\n                        ></div>\n                      </div>\n                      <p className=\"text-[10px] uppercase font-mono mt-3 tracking-widest text-stone-500\">\n                        Open cotton spread: 12\" x 9\" structural proportion\n                      </p>\n                    </div>\n                  )}\n                </div>\n\n                {/* Perspective shadow */}\n                <div className=\"w-80 h-10 bg-black/10 blur-3xl rounded-full mt-4\"></div>\n              </div>\n\n              {/* Code / Markdown Prompt Generator Output */}\n              <div className=\"bg-[#1F2022] text-[#D7CEBE] rounded-sm p-5 md:p-6 font-mono text-xs relative shadow-lg\">\n                <div className=\"flex justify-between items-center border-b border-white/10 pb-3.5 mb-3\">\n                  <div className=\"flex items-center gap-2\">\n                    <span className=\"w-2.5 h-2.5 rounded-full bg-green-500\"></span>\n                    <span className=\"text-[10px] uppercase tracking-[0.2em] font-semibold text-[#C5A059]\">\n                      Compiled Prompt Output\n                    </span>\n                  </div>\n                  <button \n                    id=\"copy-prompt-btn\"\n                    onClick={handleCopy}\n                    className=\"flex items-center gap-1.5 bg-white/5 hover:bg-white/10 text-white border border-white/10 rounded px-2.5 py-1 text-[10px] uppercase tracking-wider font-semibold transition-all cursor-pointer\"\n                  >\n                    {copied ? <Check className=\"w-3.5 h-3.5 text-green-400\" /> : <Copy className=\"w-3.5 h-3.5 text-[#C5A059]\" />}\n                    <span>{copied ? \"Copied!\" : \"Copy Markdown\"}</span>\n                  </button>\n                </div>\n\n                {/* Core Generated Text Block */}\n                <div className=\"bg-[#17181A] p-4 rounded border border-white/5 max-h-[140px] overflow-y-auto text-[11px] leading-relaxed select-all scrollbar-thin\">\n                  <p className=\"text-[#C5A059] font-bold mb-1\">// Optimized Vellum & Vestige Directive</p>\n                  <p className=\"opacity-90\">{getCompiledPrompt()}</p>\n                </div>\n\n                {/* 3-Bullet Ledger mandated by Section IV */}\n                <div className=\"mt-4 pt-4 border-t border-white/10 flex flex-wrap gap-x-6 gap-y-2 text-[9px] uppercase tracking-widest text-white/50\">\n                  <span className=\"flex items-center gap-1.5\">\n                    <span className=\"w-1.5 h-1.5 rounded-full bg-[#C5A059]\"></span>\n                    {getLedger().swatch}\n                  </span>\n                  <span className=\"flex items-center gap-1.5\">\n                    <span className=\"w-1.5 h-1.5 rounded-full bg-[#C5A059]\"></span>\n                    {getLedger().platform}\n                  </span>\n                  <span className=\"flex items-center gap-1.5\">\n                    <span className=\"w-1.5 h-1.5 rounded-full bg-[#C5A059]\"></span>\n                    {getLedger().state}\n                  </span>\n                </div>\n              </div>\n\n            </section>\n          </>\n        )}\n\n        {/* TAB 2: Brand Guide Guardrails */}\n        {activeTab === \"brand_guide\" && (\n          <section className=\"flex-1 bg-[#FAF8F5] p-6 md:p-12 overflow-y-auto max-w-4xl mx-auto\">\n            <div className=\"border-b border-[#1F2022]/10 pb-6 mb-8\">\n              <span className=\"text-[10px] tracking-[0.3em] uppercase bg-[#1F2022] text-[#D7CEBE] px-3 py-1 font-semibold rounded-sm\">\n                Master Document: Section II\n              </span>\n              <h2 className=\"text-3xl font-serif uppercase tracking-tight text-[#1F2022] mt-4\">\n                Vellum & Vestige Brand Guardrails\n              </h2>\n              <p className=\"text-sm font-serif italic text-stone-600 mt-2\">\n                \"Unyielding boundaries establishing physical, mechanical, and color compliance.\"\n              </p>\n            </div>\n\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-8 text-sm leading-relaxed\">\n              <div className=\"space-y-6\">\n                \n                {/* Rule 1 */}\n                <div className=\"border-l-2 border-[#C5A059] pl-4\">\n                  <h3 className=\"font-serif uppercase text-xs tracking-wider font-bold text-[#1F2022]\">\n                    1. Physical Portraiture & Ratio\n                  </h3>\n                  <p className=\"text-stone-700 mt-1.5 text-[13px]\">\n                    The monograph must be explicitly presented with a premium structural ratio of 12\" vertical height by 9\" width. It must possess a thick, substantial, high-density book block with layered, deckled edge lines.\n                  </p>\n                </div>\n\n                {/* Rule 2 */}\n                <div className=\"border-l-2 border-[#C5A059] pl-4\">\n                  <h3 className=\"font-serif uppercase text-xs tracking-wider font-bold text-[#1F2022]\">\n                    2. The Blank Spine Rule\n                  </h3>\n                  <p className=\"text-stone-700 mt-1.5 text-[13px]\">\n                    Under no circumstances may text, foil, or markings appear on the book spine. The spine must always be described as \"completely blank, smooth, and solid-toned cover material with zero printing.\"\n                  </p>\n                </div>\n\n                {/* Rule 3 */}\n                <div className=\"border-l-2 border-[#C5A059] pl-4\">\n                  <h3 className=\"font-serif uppercase text-xs tracking-wider font-bold text-[#1F2022]\">\n                    3. Authorized Color Palettes\n                  </h3>\n                  <div className=\"grid grid-cols-2 gap-2 mt-2\">\n                    {SWATCHES.map(s => (\n                      <div key={s.id} className=\"flex items-center gap-2 p-1.5 bg-stone-100 rounded border border-stone-200\">\n                        <span style={{ backgroundColor: s.hex }} className=\"w-5 h-5 rounded border border-black/10 block\"></span>\n                        <div className=\"text-[11px]\">\n                          <p className=\"font-bold\">{s.name}</p>\n                          <p className=\"text-[9px] font-mono\">{s.hex}</p>\n                        </div>\n                      </div>\n                    ))}\n                  </div>\n                </div>\n\n              </div>\n\n              <div className=\"space-y-6\">\n                \n                {/* Rule 4 */}\n                <div className=\"border-l-2 border-[#C5A059] pl-4\">\n                  <h3 className=\"font-serif uppercase text-xs tracking-wider font-bold text-[#1F2022]\">\n                    4. Logo hallmark hot stamp\n                  </h3>\n                  <p className=\"text-stone-700 mt-1.5 text-[13px]\">\n                    When the front cover is visible, the centered \'VV\' monogram hallmark must be explicitly described as \"centered on the upper-third of the cover, deeply blind-debossed and hot-stamped with genuine gold foil leaf.\"\n                  </p>\n                </div>\n\n                {/* Rule 5 */}\n                <div className=\"border-l-2 border-[#C5A059] pl-4\">\n                  <h3 className=\"font-serif uppercase text-xs tracking-wider font-bold text-[#1F2022]\">\n                    5. Directional Ambient Sunlight\n                  </h3>\n                  <p className=\"text-stone-700 mt-1.5 text-[13px]\">\n                    Every setting must feature natural, daylight-balanced, directional illumination. Prompts must request \"sharp, defined diagonal rays of morning sunlight casting long geometric shadows from the side,\" catching physical cover textures.\n                  </p>\n                </div>\n\n                {/* Rule 6 */}\n                <div className=\"border-l-2 border-[#C5A059] pl-4\">\n                  <h3 className=\"font-serif uppercase text-xs tracking-wider font-bold text-[#1F2022]\">\n                    6. Workspace surface\n                  </h3>\n                  <p className=\"text-stone-700 mt-1.5 text-[13px]\">\n                    Volume must be grounded upon raw, minimalist matte surfaces like raw grey concrete slabs, dark slate blocks, or coarse unbleached linen sheets. Glossy, high-reflection, or saturated surfaces are strictly forbidden.\n                  </p>\n                </div>\n\n              </div>\n            </div>\n\n            <div className=\"mt-12 bg-[#1F2022]/5 p-6 border border-[#1F2022]/10 rounded flex items-start gap-4\">\n              <Info className=\"w-5 h-5 text-[#C5A059] mt-0.5 flex-shrink-0\" />\n              <div>\n                <h4 className=\"font-bold uppercase text-xs tracking-wider text-[#1F2022]\">Compliance Ledger (Section IV)</h4>\n                <p className=\"text-xs text-stone-600 mt-1\">\n                  The final prompt compilation is designed to strictly suppress conversational introductions, friendly filler, or process explanation. Generating a clean prompt ready for Midjourney/DALL-E represents the gold standard of prompt efficiency.\n                </p>\n              </div>\n            </div>\n          </section>\n        )}\n\n        {/* TAB 3: Visual Director Notes */}\n        {activeTab === \"visual_director\" && (\n          <section className=\"flex-1 bg-[#FAF8F5] p-6 md:p-12 overflow-y-auto max-w-4xl mx-auto\">\n            <div className=\"border-b border-[#1F2022]/10 pb-6 mb-8\">\n              <span className=\"text-[10px] tracking-[0.3em] uppercase bg-[#1F2022] text-[#D7CEBE] px-3 py-1 font-semibold rounded-sm\">\n                Director Archives\n              </span>\n              <h2 className=\"text-3xl font-serif uppercase tracking-tight text-[#1F2022] mt-4\">\n                Creative Intent & Narrative Theory\n              </h2>\n              <p className=\"text-sm font-serif italic text-stone-600 mt-2\">\n                \"Understanding the soul behind Vellum & Vestige: A synthesis of tactile luxury and heartwarming humanity.\"\n              </p>\n            </div>\n\n            <div className=\"space-y-8 text-sm leading-relaxed text-stone-800\">\n              <div>\n                <h3 className=\"font-serif uppercase text-xs tracking-wider font-bold text-[#1F2022] mb-2\">\n                  The Concept of Tactile Density\n                </h3>\n                <p>\n                  A Vellum & Vestige monograph is never simply a book; it represents a physical, dense vault of memory and design excellence. This is why we emphasize the 12\"x9\" ratio and the high-density paper block. Our prompts must always explicitly specify these physical bounds to instruct AI models to render a realistic, weighty physical presence that commands respect.\n                </p>\n              </div>\n\n              <div>\n                <h3 className=\"font-serif uppercase text-xs tracking-wider font-bold text-[#1F2022] mb-2\">\n                  The Dual-Nature: Open vs. Closed Comp Design\n                </h3>\n                <p className=\"mb-3\">\n                  Our visual materials communicate two complementary aesthetics:\n                </p>\n                <ul className=\"list-disc pl-5 space-y-2 text-[13px] text-stone-700\">\n                  <li>\n                    <strong>Closed Comps:</strong> Absolute physical silence. A pristine linen or leather field punctuated solely by the gold leaf embossed monogram. The blank spine indicates complete humility and structural pureness.\n                  </li>\n                  <li>\n                    <strong>Open Spreads:</strong> Raw emotional warmth. The textured deckled edges part to reveal high-quality photography centering profound human stories, grandparents, home, or household companions. It bridges the gap between premium modernist industrial design and deep internal emotion.\n                  </li>\n                </ul>\n              </div>\n\n              <div className=\"bg-[#1F2022] text-[#D7CEBE] p-6 rounded-sm\">\n                <h4 className=\"font-serif uppercase text-xs tracking-widest text-[#C5A059] mb-2\">\n                  Lighting Doctrine: The Diagonal Rule\n                </h4>\n                <p className=\"text-[13px] opacity-95\">\n                  We never use studio softbox light or overhead flat light. Ambient morning light coming diagonally from the side (at approximately 35 degrees) creates geometric shadow lines that trace the linen fabric weave and state folds, providing realistic relief and photographic truth.\n                </p>\n              </div>\n            </div>\n          </section>\n        )}\n\n      </div>\n\n      {/* Footer Meta Details */}\n      <footer className=\"bg-[#1F2022] text-[#D7CEBE] px-6 md:px-12 py-4 flex flex-col sm:flex-row justify-between items-center text-[10px] tracking-widest uppercase border-t border-[#D7CEBE]/10 gap-3\">\n        <span>Vellum & Vestige \302\251 2026</span>\n        <div className=\"flex flex-wrap justify-center gap-6\">\n          <span>Compliance: 100% Guaranteed</span>\n          <span>Ratio: 12\" x 9\" Structural</span>\n          <span>Edge: Layered Deckle</span>\n        </div>\n      </footer>\n    </div>\n  );\n}\n"
    }

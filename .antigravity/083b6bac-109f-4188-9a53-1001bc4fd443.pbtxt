            Master Series Volume I\n                        </p>\n                      </div>"
      replacement_content: "                      {/* Logo stamp top position */}\n                      {logoPosition === \"brand_default\" && (\n                        <div className=\"flex flex-col items-center mt-12 opacity-95 animate-pulse-slow\">\n                          <div className=\"border border-[#C5A059]/50 p-2.5 bg-gradient-to-br from-[#E2C98F] via-[#C5A059] to-[#99793C] text-transparent bg-clip-text font-serif text-3xl font-bold tracking-tighter select-none shadow-[0px_2px_4px_rgba(0,0,0,0.3)]\">\n                            VV\n                          </div>\n                          <div className=\"h-14 w-[1px] bg-gradient-to-b from-[#C5A059]/40 to-transparent mt-2\"></div>\n                        </div>\n                      )}\n\n                      {/* Centered Series / Volume Title */}\n                      {logoPosition === \"user_centered_bottom\" ? (\n                        <div className=\"flex-1 flex flex-col items-center justify-center text-center px-4 relative z-10 select-none mt-12\">\n                          <p className=\"font-serif text-[10px] uppercase tracking-[0.25em] bg-gradient-to-r from-[#E2C98F] via-[#C5A059] to-[#99793C] text-transparent bg-clip-text font-semibold drop-shadow-sm\">\n                            {VOLUMES.find(v => v.id === selectedVolume)?.label}\n                          </p>\n                          <p className=\"font-serif text-[13px] md:text-sm tracking-wide bg-gradient-to-r from-[#E2C98F] via-[#C5A059] to-[#99793C] text-transparent bg-clip-text font-normal leading-relaxed drop-shadow-sm mt-1\">\n                            {VOLUMES.find(v => v.id === selectedVolume)?.title}\n                          </p>\n                          <div className=\"w-8 h-[1px] bg-gradient-to-r from-transparent via-[#C5A059]/40 to-transparent mt-2.5\"></div>\n                        </div>\n                      ) : (\n                        <div className=\"flex-1\"></div>\n                      )}\n\n                      {/* Cover Details Bottom */}\n                      <div className=\"relative z-10 text-center\">\n                        {logoPosition === \"user_centered_bottom\" ? (\n                          <div className=\"flex flex-col items-center mb-4 mt-auto select-none\">\n                            <div className=\"flex flex-col items-center opacity-95 animate-pulse-slow\">\n                              {/* Beautiful script/calligraphy style VV Monogram */}\n                              <div className=\"font-serif italic text-3xl font-light tracking-tighter bg-gradient-to-br from-[#E2C98F] via-[#C5A059] to-[#99793C] text-transparent bg-clip-text drop-shadow-[0px_1px_2px_rgba(0,0,0,0.3)] select-none leading-none\">\n                                \360\235\222\261\360\235\222\261\n                              </div>\n                              <div className=\"h-1.5 w-[1px] bg-gradient-to-b from-[#C5A059]/40 to-transparent mt-0.5\"></div>\n                              <p className=\"text-[5.5px] uppercase tracking-[0.3em] font-serif bg-gradient-to-r from-[#E2C98F] via-[#C5A059] to-[#99793C] text-transparent bg-clip-text font-bold mt-1.5\">\n                                Vellum & Vestige\n                              </p>\n                            </div>\n                          </div>\n                        ) : (\n                          <>\n                            <div className=\"h-px bg-white/10 w-full mb-2\"></div>\n                            <p className={`text-[7.5px] uppercase tracking-[0.4em] text-center ${\n                              SWATCHES.find(s => s.id === swatch)?.textLight ? \"text-white/40\" : \"text-black/40\"\n                            }`}>\n                              {VOLUMES.find(v => v.id === selectedVolume)?.label}: {VOLUMES.find(v => v.id === selectedVolume)?.title}\n                            </p>\n                          </>\n                        )}\n                      </div>"

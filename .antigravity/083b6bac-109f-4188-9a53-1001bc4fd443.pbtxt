        }
        lines {
          text: "              <span className=\"text-[10px] tracking-[0.3em] uppercase bg-[#1F2022] text-[#D7CEBE] px-3 py-1 font-semibold rounded-sm\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                Director Archives"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              </span>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              <h2 className=\"text-3xl font-serif uppercase tracking-tight text-[#1F2022] mt-4\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                Creative Intent & Narrative Theory"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              </h2>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              <p className=\"text-sm font-serif italic text-stone-600 mt-2\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                \"Understanding the soul behind Vellum & Vestige: A synthesis of tactile luxury and heartwarming humanity.\""
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              </p>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            <div className=\"space-y-8 text-sm leading-relaxed text-stone-800\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              <div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                <h3 className=\"font-serif uppercase text-xs tracking-wider font-bold text-[#1F2022] mb-2\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                  The Concept of Tactile Density"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                </h3>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                <p>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                  A Vellum & Vestige monograph is never simply a book; it represents a physical, dense vault of memory and design excellence. This is why we emphasize the 12\"x9\" ratio and the high-density paper block. Our prompts must always explicitly specify these physical bounds to instruct AI models to render a realistic, weighty physical presence that commands respect."
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                </p>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              <div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                <h3 className=\"font-serif uppercase text-xs tracking-wider font-bold text-[#1F2022] mb-2\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                  The Dual-Nature: Open vs. Closed Comp Design"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                </h3>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                <p className=\"mb-3\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                  Our visual materials communicate two complementary aesthetics:"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                </p>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                <ul className=\"list-disc pl-5 space-y-2 text-[13px] text-stone-700\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                  <li>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                    <strong>Closed Comps:</strong> Absolute physical silence. A pristine linen or leather field punctuated solely by the gold leaf embossed monogram. The blank spine indicates complete humility and structural pureness."
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                  </li>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                  <li>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                    <strong>Open Spreads:</strong> Raw emotional warmth. The textured deckled edges part to reveal high-quality photography centering profound human stories, grandparents, home, or household companions. It bridges the gap between premium modernist industrial design and deep internal emotion."
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                  </li>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                </ul>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              <div className=\"bg-[#1F2022] text-[#D7CEBE] p-6 rounded-sm\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                <h4 className=\"font-serif uppercase text-xs tracking-widest text-[#C5A059] mb-2\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                  Lighting Doctrine: The Diagonal Rule"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                </h4>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                <p className=\"text-[13px] opacity-95\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                  We never use studio softbox light or overhead flat light. Ambient morning light coming diagonally from the side (at approximately 35 degrees) creates geometric shadow lines that trace the linen fabric weave and state folds, providing realistic relief and photographic truth."
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }

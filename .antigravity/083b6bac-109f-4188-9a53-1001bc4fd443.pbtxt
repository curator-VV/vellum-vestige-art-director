        lines {
          text: "                  <li>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                    <strong>Closed Comps:</strong> Absolute physical silence. A pristine linen or leather field punctuated solely by the gold leaf embossed monogram. The blank spine indicates complete humility and structural pureness."
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
